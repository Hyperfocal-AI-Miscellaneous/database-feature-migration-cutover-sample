# Files generated by setup (not checked in)
.sandbox-connection.env
.agent-prompt.txt
hyperfocal-key.pem
hyperfocal-key.pem.pub

# Agent credentials (refreshed by control plane)
.hyperfocal/credentials.env

# Build artifacts (if agent builds locally)
/usr/local/pgsql/

# postgres-src/ is intentionally tracked (see env/README.md FAQ).
# Setup resets it via `git restore` between rollouts so the agent always
# starts from PostgreSQL 17.4 source. It is harmless to non-cutover
# problems and saves a 30s wget on every cutover rollout.
