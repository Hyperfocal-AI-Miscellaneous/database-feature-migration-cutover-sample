{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Request Latency by Endpoint (p95)",
      "description": "Total HTTP request duration, broken down by endpoint. Identifies which API endpoint is slow.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{job=\"api\"}[1m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "API Request Rate by Endpoint",
      "description": "Requests per second for each API endpoint.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(api_request_duration_seconds_count{job=\"api\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Query Latency by Endpoint (p95)",
      "description": "Database query time only (excludes API overhead). Compare with total API latency above to determine if bottleneck is DB or API.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_db_query_duration_seconds_bucket{job=\"api\"}[1m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Top Slow Queries (pg_stat_statements)",
      "description": "Top 10 queries by mean execution time from pg_stat_statements.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "topk(10, pg_stat_statements_mean_time_seconds{job=\"postgres_exporter\"}) * 1000",
          "legendFormat": "{{query}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    },
    {
      "title": "Seq Scans vs Index Scans on orders",
      "description": "Rate of sequential scans vs index scans on the orders table. High seq scan rate after adding an index indicates a planner configuration issue.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_seq_scan_total{relname=\"orders\",job=\"postgres_exporter\"}[1m])",
          "legendFormat": "seq_scan/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_user_tables_idx_scan_total{relname=\"orders\",job=\"postgres_exporter\"}[1m])",
          "legendFormat": "idx_scan/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        },
        "overrides": []
      }
    },
    {
      "title": "Active Connections",
      "description": "Database connection count by state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres_exporter\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "title": "Query Throughput (calls/sec)",
      "description": "Total database query throughput.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_statements_calls_total{job=\"postgres_exporter\"}[1m]))",
          "legendFormat": "total calls/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      }
    },
    {
      "title": "API Error Rate",
      "description": "HTTP 5xx error rate per endpoint.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(api_request_duration_seconds_count{job=\"api\",status=~\"5..\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      }
    }
  ],
